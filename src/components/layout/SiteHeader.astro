---
/**
 * SiteHeader.astro
 * Sticky navigation. Single line at desktop (max 80px height — AGENTS.md §4.7).
 * Identity links (Portfolio, GitHub, LinkedIn, Skills) always visible.
 * Mobile: hamburger overlay at ≤768px.
 */

import { EnvironmentSwitcher } from './EnvironmentSwitcher';
import { DiscoveryPrompt } from './DiscoveryPrompt';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Universe' },
  { href: '/genome', label: 'Genome' },
  { href: '/observatory', label: 'Observatory' },
  { href: '/graph', label: 'Graph' },
  { href: '/about', label: 'About' },
];

const identityLinks = [
  {
    href: 'https://rajathkiran.me',
    label: 'Portfolio',
    title: 'Rajath Kiran — Main Portfolio',
  },
  {
    href: 'https://github.com/Rajath2005',
    label: 'GitHub',
    title: 'Rajath Kiran on GitHub',
  },
  {
    href: 'http://linkedin.com/in/rajath-kiran/',
    label: 'LinkedIn',
    title: 'Rajath Kiran on LinkedIn',
  },
  {
    href: 'https://www.skills.google/public_profiles/09886862-52b8-44a4-86a5-9559a3952dd0',
    label: 'Skills',
    title: 'Google Skills Profile',
  },
];
---

<header class="site-header" role="banner">
  <div class="container-page header-inner">

    <!-- Logo / Brand -->
    <a href="/" class="header-logo" aria-label="Cloud Intelligence Center — Home">
      <span class="logo-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="10" cy="10" r="9" stroke="var(--color-accent)" stroke-width="1.5" />
          <circle cx="10" cy="10" r="3" fill="var(--color-accent)" />
          <circle cx="10" cy="3" r="1.5" fill="var(--color-accent)" opacity="0.7" />
          <circle cx="10" cy="17" r="1.5" fill="var(--color-accent)" opacity="0.7" />
          <circle cx="3" cy="10" r="1.5" fill="var(--color-accent)" opacity="0.7" />
          <circle cx="17" cy="10" r="1.5" fill="var(--color-accent)" opacity="0.7" />
        </svg>
      </span>
      <span class="logo-text">CIC</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="header-nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link"
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Desktop Identity Links -->
    <div class="header-identity" aria-label="External profiles">
      <div style="position: relative; display: flex; align-items: center;">
        <DiscoveryPrompt client:load />
        <EnvironmentSwitcher client:load />
      </div>
      <div class="identity-divider" aria-hidden="true"></div>
      {identityLinks.map((link) => (
        <a
          href={link.href}
          class="nav-link-external"
          title={link.title}
          target="_blank"
          rel="noopener noreferrer me"
        >
          {link.label}
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M1 9L9 1M9 1H3.5M9 1V6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button
      class="mobile-menu-btn"
      id="mobile-menu-btn"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation menu"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

  </div>
</header>

<!-- Mobile overlay menu -->
<div class="mobile-menu" id="mobile-menu" role="dialog" aria-modal="true" aria-label="Navigation menu" hidden>
  <div class="mobile-menu-backdrop" id="mobile-menu-backdrop"></div>
  <nav class="mobile-menu-panel">
    <button
      class="mobile-close-btn"
      id="mobile-close-btn"
      aria-label="Close navigation menu"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <ul class="mobile-nav-list" role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="mobile-nav-link">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="mobile-identity-list">
      <p class="mobile-section-label">External</p>
      {identityLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-identity-link"
          target="_blank"
          rel="noopener noreferrer me"
        >
          {link.label}
          <svg width="12" height="12" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M1 9L9 1M9 1H3.5M9 1V6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>
  </nav>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const closeBtn = document.getElementById('mobile-close-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const backdrop = document.getElementById('mobile-menu-backdrop')!;

  function openMenu() {
    menu.removeAttribute('hidden');
    btn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeMenu() {
    menu.setAttribute('hidden', '');
    btn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    btn.focus();
  }

  btn.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);
  backdrop.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu.hasAttribute('hidden')) closeMenu();
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    height: 64px;
    display: flex;
    align-items: center;
    background-color: rgba(8, 12, 20, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 32px;
    height: 100%;
  }

  /* Logo */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    display: flex;
    align-items: center;
  }

  .logo-text {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: 0.08em;
  }

  /* Desktop nav */
  .header-nav {
    flex: 1;
    display: none;
  }

  @media (min-width: 1024px) {
    .header-nav {
      display: block;
    }
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Identity links */
  .header-identity {
    display: none;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
    margin-left: auto;
  }

  @media (min-width: 1024px) {
    .header-identity {
      display: flex;
    }
  }

  .identity-divider {
    width: 1px;
    height: 20px;
    background: var(--color-border);
  }

  /* Mobile button */
  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    padding: 8px;
    margin-left: auto;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-sm);
  }

  @media (min-width: 1024px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--color-text-primary);
    border-radius: 1px;
  }

  /* Mobile menu overlay */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
  }

  .mobile-menu-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
  }

  .mobile-menu-panel {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: min(320px, 85vw);
    background: var(--color-surface-raised);
    border-left: 1px solid var(--color-border);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    overflow-y: auto;
  }

  .mobile-close-btn {
    align-self: flex-end;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    border-radius: var(--radius-sm);
  }

  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-nav-link {
    display: block;
    padding: 12px 16px;
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text-primary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background-color 150ms ease;
  }

  .mobile-nav-link:hover {
    background: var(--color-surface);
    color: var(--color-accent);
  }

  .mobile-section-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin: 0 0 8px;
  }

  .mobile-identity-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-identity-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color 150ms ease, background-color 150ms ease;
  }

  .mobile-identity-link:hover {
    color: var(--color-accent);
    background: var(--color-surface);
  }
</style>
