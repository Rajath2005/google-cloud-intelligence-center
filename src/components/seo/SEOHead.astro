---
/**
 * SEOHead.astro
 * Injects all required SEO meta tags into <head>.
 * Every page must include this component.
 *
 * AGENTS.md compliance:
 *   - Unique title per page (50-60 chars)
 *   - Unique meta description (150-160 chars)
 *   - Self-referencing canonical URL
 *   - OG + Twitter cards
 *   - json-ld injected separately via JsonLD.astro
 */

interface Props {
  title: string;
  description: string;
  /** Absolute canonical URL for this page */
  canonicalUrl: string;
  /** OG image URL — use absolute URL */
  ogImage?: string;
  /** 'website' for index pages, 'article' for badge/tech/category pages */
  ogType?: 'website' | 'article';
  /** Noindex specific pages (e.g. 404) */
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage = 'https://cloud.rajathkiran.me/og-default.png',
  ogType = 'website',
  noindex = false,
} = Astro.props;

const siteTitle = 'Cloud Intelligence Center';
const fullTitle = title.includes(siteTitle) ? title : `${title} | ${siteTitle}`;
---

<!-- Primary -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:160, max-image-preview:large'} />

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_US" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Performance hints -->
<link rel="preconnect" href="https://cdn.simpleicons.org" crossorigin />
<link rel="dns-prefetch" href="https://cdn.simpleicons.org" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
