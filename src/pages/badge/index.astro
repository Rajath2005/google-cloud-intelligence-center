---
/**
 * /badge/index.astro — Badge listing page
 * Lists all earned badges with filtering by category and difficulty.
 * SEO: ItemList JSON-LD, keyword-first title
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLD from '../../components/seo/JsonLD.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const badgeEntries = await getCollection('badges');
const categoryEntries = await getCollection('categories');

const badges = badgeEntries.map((e) => e.data);
const categories = categoryEntries.map((e) => e.data);

const categoryMap = new Map(categories.map((c) => [c.id, c]));

const categoryColorMap: Record<string, string> = {
  'ai-and-ml': '#4285f4',
  'data-analytics': '#fbbc04',
  'cloud-infrastructure': '#34a853',
  'networking': '#ea4335',
  'security': '#ff6d00',
  'devops': '#00bcd4',
  'application-development': '#ab47bc',
};

const difficultyLabel: Record<string, string> = {
  introductory: 'Introductory',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

// Sort by earnedDate descending
const sortedBadges = [...badges].sort((a, b) => {
  if (!a.earnedDate && !b.earnedDate) return 0;
  if (!a.earnedDate) return 1;
  if (!b.earnedDate) return -1;
  return a.earnedDate > b.earnedDate ? -1 : 1;
});

// JSON-LD: ItemList
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Google Cloud Skill Badges — Rajath Kiran',
  description: "All Google Cloud skill badges and credentials earned by Rajath Kiran on Google Cloud Skills Boost.",
  url: 'https://cloud.rajathkiran.me/badge',
  numberOfItems: badges.length,
  itemListElement: sortedBadges.map((badge, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://cloud.rajathkiran.me/badge/${badge.id}`,
    name: badge.name,
  })),
};
---

<BaseLayout
  title={`Google Cloud Badges — Rajath Kiran | Cloud Intelligence Center`}
  description={`All ${badges.length} Google Cloud skill badges earned by Rajath Kiran on Skills Boost. Browse by category, difficulty, and technology.`}
>
  <Fragment slot="head">
    <JsonLD schema={itemListSchema} />
  </Fragment>

  <div class="container-page badges-list-page">

    <Breadcrumbs
      items={[
        { name: 'Home', href: '/' },
        { name: 'Badges' },
      ]}
    />

    <div class="page-header">
      <h1 class="page-title">Badges</h1>
      <p class="page-subtitle">
        <span class="stat-mono">{badges.length}</span> Google Cloud skill badges earned across{' '}
        <span class="stat-mono">{categories.length}</span> domains.
      </p>
    </div>

    <!-- Category filter tabs -->
    <div class="category-tabs" role="navigation" aria-label="Filter badges by category">
      <a
        href="/badge"
        class="category-tab category-tab-active"
        aria-current="page"
      >
        All <span class="category-tab-count">{badges.length}</span>
      </a>
      {categories.map((cat) => {
        const count = badges.filter((b) => b.category === cat.id).length;
        if (count === 0) return null;
        const color = categoryColorMap[cat.id] ?? '#4285f4';
        return (
          <a
            href={`/category/${cat.id}`}
            class="category-tab"
            style={`--cat-color: ${color}`}
          >
            <span class="category-tab-dot" aria-hidden="true"></span>
            {cat.shortName}
            <span class="category-tab-count">{count}</span>
          </a>
        );
      })}
    </div>

    <!-- Badge grid -->
    <ul class="badge-list" role="list" aria-label="Badge list">
      {sortedBadges.map((badge) => {
        const cat = categoryMap.get(badge.category);
        const color = categoryColorMap[badge.category] ?? '#4285f4';
        return (
          <li>
            <a href={`/badge/${badge.id}`} class="badge-list-card surface-card hover-lift">
              <div class="badge-list-image-wrap">
                <img
                  src={badge.badgeImageUrl}
                  alt={`${badge.name} badge`}
                  width="64"
                  height="64"
                  class="badge-list-image"
                  loading="lazy"
                />
              </div>
              <div class="badge-list-content">
                {cat && (
                  <span class="badge-list-category" style={`color: ${color}`}>
                    {cat.shortName}
                  </span>
                )}
                <h2 class="badge-list-title">{badge.name}</h2>
                <p class="badge-list-desc">{badge.description.slice(0, 90)}…</p>
              </div>
              <div class="badge-list-meta">
                <span class={`badge-pill difficulty-${badge.difficulty}`}>
                  {difficultyLabel[badge.difficulty]}
                </span>
                {badge.earnedDate && (
                  <time class="badge-list-date" datetime={badge.earnedDate}>
                    {new Date(badge.earnedDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                  </time>
                )}
              </div>
            </a>
          </li>
        );
      })}
    </ul>

  </div>
</BaseLayout>

<style>
  .badges-list-page {
    padding-top: 32px;
    padding-bottom: 96px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .page-header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .page-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin: 0;
  }

  .page-subtitle {
    font-size: 16px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .stat-mono {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-accent);
  }

  /* Category tabs */
  .category-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .category-tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    background: transparent;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: border-color 150ms ease, color 150ms ease, background 150ms ease;
    white-space: nowrap;
  }

  .category-tab:hover {
    color: var(--color-text-primary);
    border-color: var(--cat-color, var(--color-accent));
  }

  .category-tab-active {
    background: var(--color-accent-dim);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .category-tab-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cat-color, var(--color-accent));
    flex-shrink: 0;
  }

  .category-tab-count {
    font-family: var(--font-mono);
    font-size: 11px;
    opacity: 0.7;
  }

  /* Badge list */
  .badge-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .badge-list-card {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    align-items: center;
    gap: 20px;
    padding: 20px;
    text-decoration: none;
    transition: border-color 200ms ease, transform 150ms ease, box-shadow 150ms ease;
  }

  @media (max-width: 640px) {
    .badge-list-card {
      grid-template-columns: 56px 1fr;
      grid-template-rows: auto auto;
    }
    .badge-list-meta {
      grid-column: 2;
    }
  }

  .badge-list-image-wrap {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-sm);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .badge-list-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .badge-list-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .badge-list-category {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: var(--font-mono);
  }

  .badge-list-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .badge-list-desc {
    font-size: 13px;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .badge-list-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex-shrink: 0;
  }

  .badge-list-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-tertiary);
  }
</style>
